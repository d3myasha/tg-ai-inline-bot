TELEGRAM_BOT_TOKEN=123456:ABC-DEF
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# Optional whitelist after GET /v1/models (comma-separated). Empty = all from API.
AVAILABLE_MODELS=
MODELS_CACHE_TTL_SECONDS=300
# Optional: comma-separated Telegram user IDs; empty = allow everyone
ALLOWED_TELEGRAM_USER_IDS=
ASSISTANT_SYSTEM_PROMPT=You are a helpful assistant. Answer in the user's language. Use Markdown (**bold**, lists, `code`).